{
	"info": {
		"_postman_id": "streampulse-collection",
		"name": "StreamPulse Backend API",
		"description": "Complete API collection for the StreamPulse Video Streaming Platform microservices backend.\n\nServices:\n- Video Service (port 8081)\n- User Service (port 8082)\n- Gateway (port 8080)\n\nAll requests go through the API Gateway at {{baseUrl}} (default: http://localhost:8080).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8090",
			"type": "string"
		},
		{
			"key": "videoServiceUrl",
			"value": "http://localhost:8081",
			"type": "string"
		},
		{
			"key": "userServiceUrl",
			"value": "http://localhost:8082",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"description": "JWT Authentication — Register and Login to obtain a Bearer token. The token is automatically saved to {{jwt_token}} variable.",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('jwt_token', jsonData.token);",
									"    pm.test('Token saved to collection variable', function() {",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePass123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
					}
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('jwt_token', jsonData.token);",
									"    pm.test('Token saved to collection variable', function() {",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"securePass123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
					}
				}
			]
		},
		{
			"name": "Video Service",
			"description": "CRUD operations, search, filtering, and TMDb integration for video content.",
			"item": [
				{
					"name": "Create Video",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Inception\",\n  \"description\": \"A thief who steals corporate secrets through dream-sharing technology.\",\n  \"thumbnailUrl\": \"https://image.tmdb.org/t/p/w500/ljsZTbVsrQSqZgWeep2B1QiDKuh.jpg\",\n  \"trailerUrl\": \"https://www.youtube.com/embed/YoHD9XEInc0\",\n  \"duration\": 148,\n  \"releaseYear\": 2010,\n  \"type\": \"FILM\",\n  \"category\": \"SCIENCE_FICTION\",\n  \"rating\": 8.8,\n  \"director\": \"Christopher Nolan\",\n  \"cast\": \"Leonardo DiCaprio, Joseph Gordon-Levitt, Elliot Page\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/videos", "host": ["{{baseUrl}}"], "path": ["api", "videos"] }
					}
				},
				{
					"name": "Get All Videos",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos", "host": ["{{baseUrl}}"], "path": ["api", "videos"] }
					}
				},
				{
					"name": "Get All Videos (filter by type)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/videos?type=FILM",
							"host": ["{{baseUrl}}"],
							"path": ["api", "videos"],
							"query": [{ "key": "type", "value": "FILM" }]
						}
					}
				},
				{
					"name": "Get All Videos (filter by category)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/videos?category=ACTION",
							"host": ["{{baseUrl}}"],
							"path": ["api", "videos"],
							"query": [{ "key": "category", "value": "ACTION" }]
						}
					}
				},
				{
					"name": "Get All Videos (filter by type + category)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/videos?type=FILM&category=SCIENCE_FICTION",
							"host": ["{{baseUrl}}"],
							"path": ["api", "videos"],
							"query": [
								{ "key": "type", "value": "FILM" },
								{ "key": "category", "value": "SCIENCE_FICTION" }
							]
						}
					}
				},
				{
					"name": "Get Video by ID",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/1", "host": ["{{baseUrl}}"], "path": ["api", "videos", "1"] }
					}
				},
				{
					"name": "Update Video",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Inception (Updated)\",\n  \"description\": \"Updated description for Inception.\",\n  \"thumbnailUrl\": \"https://image.tmdb.org/t/p/w500/ljsZTbVsrQSqZgWeep2B1QiDKuh.jpg\",\n  \"trailerUrl\": \"https://www.youtube.com/embed/YoHD9XEInc0\",\n  \"duration\": 148,\n  \"releaseYear\": 2010,\n  \"type\": \"FILM\",\n  \"category\": \"SCIENCE_FICTION\",\n  \"rating\": 9.0,\n  \"director\": \"Christopher Nolan\",\n  \"cast\": \"Leonardo DiCaprio, Joseph Gordon-Levitt, Elliot Page, Tom Hardy\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/videos/1", "host": ["{{baseUrl}}"], "path": ["api", "videos", "1"] }
					}
				},
				{
					"name": "Delete Video",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/1", "host": ["{{baseUrl}}"], "path": ["api", "videos", "1"] }
					}
				},
				{
					"name": "Search Videos by Title",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/videos/search?title=inception",
							"host": ["{{baseUrl}}"],
							"path": ["api", "videos", "search"],
							"query": [{ "key": "title", "value": "inception" }]
						}
					}
				},
				{
					"name": "Filter by Type (FILM)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/type/FILM", "host": ["{{baseUrl}}"], "path": ["api", "videos", "type", "FILM"] }
					}
				},
				{
					"name": "Filter by Type (SERIE)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/type/SERIE", "host": ["{{baseUrl}}"], "path": ["api", "videos", "type", "SERIE"] }
					}
				},
				{
					"name": "Filter by Category (ACTION)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/category/ACTION", "host": ["{{baseUrl}}"], "path": ["api", "videos", "category", "ACTION"] }
					}
				},
				{
					"name": "TMDb — Search Movie",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/videos/tmdb/search?title=The Matrix",
							"host": ["{{baseUrl}}"],
							"path": ["api", "videos", "tmdb", "search"],
							"query": [{ "key": "title", "value": "The Matrix" }]
						}
					}
				},
				{
					"name": "TMDb — Import Movie by TMDb ID",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/videos/tmdb/import/603", "host": ["{{baseUrl}}"], "path": ["api", "videos", "tmdb", "import", "603"] }
					}
				}
			]
		},
		{
			"name": "User Service",
			"description": "User CRUD, watchlist management, viewing history, and statistics.",
			"item": [
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePass123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
					}
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1"] }
					}
				},
				{
					"name": "Update User (partial — username only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"john_updated\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/users/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1"] }
					}
				},
				{
					"name": "Update User (full — with password change)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"john_v2\",\n  \"email\": \"john_v2@example.com\",\n  \"password\": \"newPassword456\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/users/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1"] }
					}
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1"] }
					}
				},
				{
					"name": "Add Video to Watchlist",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1/watchlist/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "watchlist", "1"] }
					}
				},
				{
					"name": "Get User Watchlist",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1/watchlist", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "watchlist"] }
					}
				},
				{
					"name": "Remove Video from Watchlist",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1/watchlist/1", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "watchlist", "1"] }
					}
				},
				{
					"name": "Record Viewing Event",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"videoId\": 1,\n  \"progressTime\": 85,\n  \"completed\": false\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/users/1/history", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "history"] }
					}
				},
				{
					"name": "Record Viewing Event (completed)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"videoId\": 1,\n  \"progressTime\": 148,\n  \"completed\": true\n}"
						},
						"url": { "raw": "{{baseUrl}}/api/users/1/history", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "history"] }
					}
				},
				{
					"name": "Get Viewing History",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1/history", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "history"] }
					}
				},
				{
					"name": "Get Viewing Statistics",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"url": { "raw": "{{baseUrl}}/api/users/1/stats", "host": ["{{baseUrl}}"], "path": ["api", "users", "1", "stats"] }
					}
				}
			]
		},
		{
			"name": "Infrastructure",
			"description": "Health checks, Eureka dashboard, and config refresh endpoints.",
			"item": [
				{
					"name": "Gateway Health",
					"request": {
						"method": "GET",
						"url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] }
					}
				},
				{
					"name": "Video Service Health",
					"request": {
						"method": "GET",
						"url": { "raw": "{{videoServiceUrl}}/actuator/health", "host": ["{{videoServiceUrl}}"], "path": ["actuator", "health"] }
					}
				},
				{
					"name": "User Service Health",
					"request": {
						"method": "GET",
						"url": { "raw": "{{userServiceUrl}}/actuator/health", "host": ["{{userServiceUrl}}"], "path": ["actuator", "health"] }
					}
				},
				{
					"name": "Video Service — Refresh Config",
					"request": {
						"method": "POST",
						"url": { "raw": "{{videoServiceUrl}}/actuator/refresh", "host": ["{{videoServiceUrl}}"], "path": ["actuator", "refresh"] }
					}
				},
				{
					"name": "User Service — Refresh Config",
					"request": {
						"method": "POST",
						"url": { "raw": "{{userServiceUrl}}/actuator/refresh", "host": ["{{userServiceUrl}}"], "path": ["actuator", "refresh"] }
					}
				},
				{
					"name": "Eureka Dashboard",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8761", "host": ["http://localhost:8761"], "path": [] }
					}
				},
				{
					"name": "Video Service — Swagger UI",
					"request": {
						"method": "GET",
						"url": { "raw": "{{videoServiceUrl}}/swagger-ui.html", "host": ["{{videoServiceUrl}}"], "path": ["swagger-ui.html"] }
					}
				},
				{
					"name": "User Service — Swagger UI",
					"request": {
						"method": "GET",
						"url": { "raw": "{{userServiceUrl}}/swagger-ui.html", "host": ["{{userServiceUrl}}"], "path": ["swagger-ui.html"] }
					}
				}
			]
		}
	]
}
